{
  "_comment": "Foundation Create workflow semantic registry. Driven by V2.0 FOUNDATION/SCOPE/PRD. No hardcoded business logic in handlers.",

  "workflows": {
    "v2_0": {
      "stages": {
        "foundation_create": {
          "command_intent": "start_foundation_delivery",
          "description": "Begin V2.0 Foundation document delivery workflow",

          "artifact_binding": {
            "output_artifact": "V2_0_FOUNDATION.md",
            "artifact_type": "foundation",
            "output_path": "governance/docs/V2_0_FOUNDATION.md"
          },

          "doctrine_loading_set": [
            "v2_0_foundation_doctrine",
            "skos_source_model"
          ],

          "skill_handler_binding": {
            "handler": "handle_foundation_create",
            "skill": "foundation_delivery",
            "skill_type": "delivery"
          },

          "message_contract": {
            "required_fields": [
              "message_id",
              "collab_id",
              "message_type",
              "from",
              "to",
              "command_intent",
              "artifact_type",
              "artifact_path",
              "payload",
              "summary"
            ],
            "message_type": "foundation_create"
          },

          "expected_output": {
            "message_type": "foundation_response",
            "artifacts_produced": [
              "V2_0_FOUNDATION.md"
            ],
            "completion_signal": "foundation_delivered"
          },

          "completion_criteria": {
            "success": [
              "artifact_written",
              "artifact_verified",
              "completion_acked"
            ],
            "failure": [
              "artifact_write_failed",
              "doctrine_load_failed",
              "timeout"
            ],
            "status_on_success": "completed",
            "pending_action_on_success": ""
          }
        }
      }
    }
  }
}